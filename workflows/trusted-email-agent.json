              "content": "={{ 'Classify this email into exactly one category: sales, support, refund, complaint, or general.\\n\\nFrom: ' + $json.from + '\\nSubject: ' + $json.subject + '\\nBody: ' + $json.body + '\\n\\nRespond with ONLY the category name, nothing else.' }}"
