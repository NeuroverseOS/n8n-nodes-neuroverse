      "id": "bf797e59-b935-4fd7-982a-f22e95f82b2f",
      "name": "Prepare Guard Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-1024, -16]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4",
          "mode": "list",
          "cachedResultName": "GPT-4"
        },
        "messages": {
          "values": [
            {
              "content": "={{ 'Evaluate this AI-generated email reply for quality and safety.\\n\\nOriginal email category: ' + $json.email_category + '\\nDraft reply:\\n' + $json.draft_reply + '\\n\\nScore each dimension from 1-10:\\n1. Accuracy — does the reply address the customer\\'s actual concern?\\n2. Professional Tone — is the language appropriate and empathetic?\\n3. Policy Compliance — does it avoid making commitments the AI shouldn\\'t make?\\n\\nThen provide an overall verdict: PASS, REVIEW, or FAIL.\\n\\nRespond in this exact JSON format:\\n{\"accuracy\": N, \"tone\": N, \"compliance\": N, \"verdict\": \"PASS|REVIEW|FAIL\", \"notes\": \"brief explanation\"}' }}"
            }
          ]
        },
        "options": {
          "temperature": 0
        }
      },
      "id": "34a2b4c0-4462-4827-9bb8-d21761dbb348",
      "name": "AI Evaluation",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [-336, -192],
      "credentials": {
        "openAiApi": {
          "id": "jCv9rjF5Pi3RVIPB",
          "name": "OpenAi account"
        }
      },
      "notes": "Scores the reply for accuracy, tone, and policy compliance"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "evaluation",
              "name": "evaluation",
              "value": "={{ JSON.parse($json.message.content) }}",
              "type": "string"
            },
            {
              "id": "draft_reply",
              "name": "draft_reply",
              "value": "={{ $('Prepare Guard Input').item.json.draft_reply }}",
              "type": "string"
            },
            {
              "id": "from",
              "name": "from",
              "value": "={{ $('Prepare Guard Input').item.json.from }}",
              "type": "string"
            },
            {
              "id": "subject",
