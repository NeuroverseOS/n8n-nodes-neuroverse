    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfor (const item of items) {\n\n  const verdict = item.json.verdict || {};\n  const evidence = item.json.evidence || {};\n\n  item.json.audit_record = {\n    timestamp: new Date().toISOString(),\n    decision: verdict.status || \"UNKNOWN\",\n    rule_triggered: verdict.ruleId || null,\n    reason: verdict.reason || null,\n    \n    email: {\n      from: item.json.from,\n      subject: item.json.subject,\n      category: item.json.email_category\n    },\n\n    governance_world: {\n      id: evidence.worldId,\n      name: evidence.worldName,\n      version: evidence.worldVersion\n    }\n  };\n\n}\n\nreturn items;"
      },
