      "id": "4d7f70a9-7c2e-4688-aa5e-3de0ef97c7b7",
      "name": "Set Category",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-1456, -16]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4",
          "mode": "list",
          "cachedResultName": "GPT-4"
        },
        "messages": {
          "values": [
            {
              "content": "={{ 'You are a support agent for Nexus Integrations. Draft a professional reply to this ' + $json.email_category + ' email.\\n\\nFrom: ' + $json.from + '\\nSubject: ' + $json.subject + '\\nBody: ' + $json.body + '\\n\\nRules:\\n- Be professional and empathetic\\n- Acknowledge the customer\\'s concern\\n- For refund requests: acknowledge receipt only, say the billing team will review within 24-48 hours\\n- For complaints: empathize and escalate to support team\\n- Never promise refunds, discounts, or make legal statements\\n- Sign as \"Nexus Integrations Support\"\\n\\nWrite only the reply email body, nothing else.' }}"
            }
          ]
        },
        "options": {
          "temperature": 0.3
        }
      },
      "id": "8ff4b5f4-088b-44e4-92a6-776bbaaa5535",
      "name": "Draft Reply",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [-1232, -16],
      "credentials": {
        "openAiApi": {
          "id": "jCv9rjF5Pi3RVIPB",
          "name": "OpenAi account"
        }
      },
      "notes": "Generates the email reply — governed by NeuroVerse Guard downstream"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "draft_reply",
              "name": "draft_reply",
              "value": "={{ $json.message.content }}",
              "type": "string"
            },
            {
              "id": "intent",
              "name": "intent",
              "value": "={{ 'Send ' + $('Set Category').item.json.email_category + ' reply: ' + $json.message.content.substring(0, 200) }}",
              "type": "string"
            },
            {
              "id": "email_category",
              "name": "email_category",
              "value": "={{ $('Set Category').item.json.email_category }}",
              "type": "string"
            },
            {
